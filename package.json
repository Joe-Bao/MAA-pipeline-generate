{
  "name": "@joebao/maa-pipeline-generate",
  "version": "1.0.4",
  "description": "Batch-generate MAA pipeline JSON from templates and data (CLI + browser GUI).",
  "author": "maa-support-extension",
  "type": "module",
  "main": "server.mjs",
  "bin": {
    "maa-pipeline-generate": "bin/maa-pipeline-generate.mjs",
    "maa-pipeline-generate-gui": "bin/maa-pipeline-generate-gui.mjs",
    "maa-pipeline-generate-task": "bin/maa-pipeline-generate-task.mjs"
  },
  "files": [
    "bin/**/*.mjs",
    "config.json",
    "lib/**/*.mjs",
    "template.jsonc",
    "data.json",
    "public/**",
    "scripts/download-portable-node.mjs",
    "generate.mjs",
    "generate-task.mjs",
    "server.mjs",
    "start.bat",
    "start.sh"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Joe-Bao/MAA-pipeline-generate.git"
  },
  "scripts": {
    "generate": "node generate.mjs",
    "generate:task": "node generate-task.mjs",
    "start:gui": "node server.mjs",
    "start:gui:no-open": "node server.mjs --no-open",
    "download:node": "node scripts/download-portable-node.mjs"
  },
  "dependencies": {
    "@nekosu/maa-pipeline-manager": "^1.0.5",
    "jsonc-parser": "^3.3.1"
  }
}
